# Multi-Confluence Scalper Configuration
# 24/7 scalping strategy with 4-layer confluence model

# Exchange keys (copy from main .env or set here)
BINANCE_API_KEY = "MbHuigPGXZXA7HkW0uywfBjl9OrFqHDDyEMVKtZ3rKiptrmZRhCZZA31Pavh0OOE"
BINANCE_API_SECRET = "s4iBFHwMpqleOQkWYm1QvCiMXuTKV7TPkqzeXZRn3CGcgjG75rbNrBH5O2s3tYtU"

# Telegram
TELEGRAM_BOT_TOKEN=8161261581:AAG2mKYaL7bN1USVHbSGFs3Gol5V1YuhGbs
TELEGRAM_CHAT_ID=377998110
# Symbols to trade
SCALP_SYMBOLS=SOL/USDT

# Check interval (seconds) - for 15m timeframe trading
SCALP_CHECK_INTERVAL=60

# Debug mode - log rejection reasons and layer-by-layer analysis
# true = detailed logs for debugging (50-100 messages/hour)
# false = production mode, only important events (12-20 messages/hour)
SCALP_DEBUG=false

# ========== LAYER 1: MARKET STRUCTURE ==========
# Timeframes for analysis (15m main timeframe)
SCALP_HTF_TIMEFRAME=1h
SCALP_MTF_TIMEFRAME=15m
SCALP_LTF_TIMEFRAME=15m

# Trend filter EMAs (15m chart)
SCALP_TREND_EMA_FAST=50
SCALP_TREND_EMA_SLOW=200

# Bias candle count (5m chart - check last N candles for color consistency)
SCALP_BIAS_CANDLE_COUNT=5

# ========== LAYER 2: PATTERN DETECTION ==========
# ACTIVE LAYERS: Layer 1 (Market Structure) + FVG + Layer 4 (RSI)
# Layer 2 (S/D zones, trendlines, double touch) and Layer 3 (volume, spread) DISABLED for simplicity

# Enable/disable specific patterns
SCALP_ENABLE_FVG=true
SCALP_ENABLE_SD_ZONES=false
SCALP_ENABLE_TRENDLINE=false
SCALP_ENABLE_DOUBLE_TOUCH=false

# ========================================
# FVG Configuration (NY Open Style)
# ========================================
# Uses same ATR-based filtering as NY Open FVG strategy for consistency
# MIN_FVG_ATR_MULTIPLIER: Minimum FVG gap size as multiple of ATR
# Lower values = more signals, higher values = better quality
# Recommended: 0.3-0.5 for scalping (more active than NY Open's 0.5)
MIN_FVG_ATR_MULTIPLIER=0.35

# FVG_ATR_PERIOD: ATR calculation period for gap size validation
FVG_ATR_PERIOD=14

# FVG_MAX_AGE_MINUTES: Maximum age of FVG pattern to trade (prevents stale patterns)
# Don't trade FVGs older than this (in 1m candles = minutes)
# Recommended: 60-120 minutes for scalping (1-2 hours max)
FVG_MAX_AGE_MINUTES=120

# FVG_PATTERN_CACHE_SIZE: Number of recently used FVG indices to remember
# Prevents immediate re-entry on same FVG after trade closes
FVG_PATTERN_CACHE_SIZE=50

# FVG_RR: Risk-reward ratio for FVG trades (SL at gap boundary, TP based on RR)
# Note: Scalper uses multiple TPs, this is the base RR for TP1
FVG_RR=1.5

# Fallback filters (used if ATR unavailable)
FVG_MIN_GAP_PCT=0.08
FVG_MIN_GAP_POINTS=0.01

# FVG Entry Logic (matches NY Open strategy):
# 1. Detect FVG gap formation
# 2. Wait for candle to ENTER gap zone (wick touch)
# 3. Check close direction:
#    - CONTINUATION: Candle closes in FVG direction → Enter that direction
#    - INVERSION: Candle closes opposite to FVG → Enter opposite direction
# 4. SL: At opposite gap boundary
# 5. TP: Based on FVG_RR multiplier

# ========== LAYER 3: CONFIRMATION FILTERS ==========
# Layer 3 can be tuned or disabled for more aggressive scalping
# Set multipliers to 0 to disable specific checks

# Volume expansion requirement (trigger candle vs recent average)
# Higher values = stricter filter (need strong volume)
# Lower values = more signals (allow moderate volume)
# Set to 0 to disable volume check entirely
# Recommended: 1.1-1.3 for active scalping, 0 to disable
SCALP_VOL_MULT=0
SCALP_VOL_LOOKBACK=20

# ATR ratio (LTF ATR vs HTF ATR - ensures market is moving)
# For scalping, this should be LOW since 1m ATR is naturally much smaller than 15m ATR
# Set to 0 to disable this check entirely
# Recommended: 0.15-0.25 for scalping (was 0.5 for swing trading)
SCALP_ATR_RATIO_MIN=0

# Spread check (max bid-ask spread as % of price)
# SCALP_SPREAD_MAX_PCT=0.05

# Post-trade cooldowns (prevent immediate re-entry on stale patterns)
# General cooldown after ANY trade (win or loss) - prevents chasing same setup
SCALP_POST_TRADE_COOLDOWN_SEC=900  # 15 minutes after any trade

# Additional cooldown specifically after losses (stacks with general cooldown)
SCALP_MIN_LOSS_COOLDOWN_SEC=900  # 30 minutes after loss (was 10 min)

# ========== LAYER 4: MULTI-TIMEFRAME ALIGNMENT ==========
# RSI overbought/oversold thresholds (15m chart)
# Don't long if RSI > 75, don't short if RSI < 25
SCALP_RSI_OVERBOUGHT=75
SCALP_RSI_OVERSOLD=25

# ========== TIME-OF-DAY WEIGHTS ==========
# High priority hours (1.0x confidence) - London + NY sessions
SCALP_HIGH_PRIORITY_HOURS=8-17

# Medium priority hours (0.8x confidence) - Asian + NY afternoon
SCALP_MED_PRIORITY_HOURS=0-8,17-20

# Low priority hours (0.6x confidence) - After hours
SCALP_LOW_PRIORITY_HOURS=20-24

# ========== RISK MANAGEMENT ==========
# Risk per trade (% of price movement for SL)
# 1% price SL with 10x leverage = -10% ROE per trade
SCALP_RISK_PCT=1.0

# Min/Max SL distance (% of entry price)
SCALP_MIN_SL_PCT=0.75
SCALP_MAX_SL_PCT=1.5

# Position sizing (notional USDT per trade)
RISK_NOTIONAL_USDT=80

# ========== EXIT MANAGEMENT ==========
# Take Profit RR ratios (based on 1% SL)
# TP1: 1.5% price = 1.5 RR = +15% ROE (close 50%)
# TP2: 2% price = 2.0 RR = +20% ROE (close 25%)
# TP3: 2.5% price = 2.5 RR = +25% ROE (close rest)
SCALP_TP1_RR=1.5
SCALP_TP2_RR=2.0
SCALP_TP3_RR=2.5

# TP quantity percentages (last value 100 means "close remaining")
# This ensures no dust is left from rounding errors
SCALP_TP_QTY_PCT=50,25,100

# Trailing stop configuration
SCALP_ENABLE_TRAILING=true
SCALP_TRAIL_AFTER_PROFIT_PCT=1.5  # Start trailing after TP1 (1.5% profit)
SCALP_TRAIL_ATR_MULT=0.5  # Trail by 0.5x ATR
SCALP_BREAKEVEN_AT_PCT=0.5  # Move SL to +0.5% price (+5% ROE) after TP1 hit

# Momentum exit (consecutive candles against you)
SCALP_MOMENTUM_EXIT_CANDLES=3

# Time-based exit (if no progress after X minutes) - adjusted for 15m timeframe
SCALP_TIME_EXIT_MINUTES=120

# ========== TRADING CONTROLS ==========
# Max trades per symbol per day (reduced for quality over quantity)
SCALP_MAX_TRADES_PER_DAY=30

# Daily loss cap (stop trading after this loss)
SCALP_DAILY_LOSS_CAP_USDT=100

# Max concurrent positions (1 = only one position at a time)
SCALP_MAX_CONCURRENT_POSITIONS=1

# ========== BRACKET MODE ==========
# Use LADDER mode for 15m timeframe trading (partial exits)
BRACKET_MODE=LADDER

# Ladder configuration (optimized for 15-minute timeframe)
# With 10x leverage: Price% × 10 = ROE%
# TP1: 1.5% price = 15% ROE (close 50%)
# TP2: 2% price = 20% ROE (close 25%)
# TP3: 2.5% price = 25% ROE (close rest)
LADDER_TP_PCT=15,20,25  # ROE % targets for 15m trading with 10x leverage
LADDER_TP_QTY_PCT=50,25,100  # Last value 100 = close all remaining (prevents dust)
LADDER_SL_PCT=-10  # Initial SL at -10% ROE (1% price move with 10x leverage)

# Leverage and margin
LEVERAGE=10
MARGIN_MODE=isolated

# Fees
FEE_TAKER_PCT=0.0005
