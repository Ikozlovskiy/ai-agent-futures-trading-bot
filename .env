# Symbols (comma-separated) — USDT-M perps
SYMBOLS=ETH/USDT,SOL/USDT,DOGE/USDT,BTC/USDT,XRP/USDT
# For NY-Open FVG runner only (overrides SYMBOLS if present)
NY_OPEN_SYMBOLS=ETH/USDT

# OR_START_UTC: Opening Range start time in UTC (NOT local time)
# 13:30 UTC = New York market open (9:30 AM EST)
# For Ukraine (UTC+2 winter / UTC+3 summer): This is 15:30 or 16:30 local time
# All strategy logic and logs use UTC for consistency with exchange timestamps
OR_START_UTC=13:30
OR_MINUTES=15
# OR_TIMEFRAME: Timeframe for opening range candle (e.g., 15m)
OR_TIMEFRAME=15m
# FVG_TIMEFRAME: Timeframe for FVG detection (e.g., 1m for precise entry timing)
FVG_TIMEFRAME=1m
# FVG_SIGNAL_CHECK_INTERVAL: How often to check for NEW TRADE SIGNALS in seconds (set to 60s to align with 1m candle closes)
# This controls how frequently the strategy looks for new FVG opportunities
FVG_SIGNAL_CHECK_INTERVAL=60
# FVG_RR: Risk-reward ratio for FVG trades (SL at FVG boundary, TP = entry + RR*risk)
FVG_RR=2.3

# ========================================
# FVG ATR-Based Filtering (NEW)
# ========================================
# MIN_FVG_ATR_MULTIPLIER: Minimum FVG gap size as multiple of ATR to filter out noise
# Lower values = more signals but potentially lower quality
# Higher values = fewer but cleaner signals
# Recommended: 0.3-0.7 for active trading, 0.5-1.0 for conservative
# Example: With ATR=50 and multiplier=0.5, only FVGs with gap > $25 are considered
MIN_FVG_ATR_MULTIPLIER=0.5

# FVG_ATR_PERIOD: ATR calculation period for FVG size filtering (default: 14)
# Standard ATR period, rarely needs adjustment
FVG_ATR_PERIOD=14

# ========================================
# FVG Gap Size Filters (Fallback)
# ========================================
# These are fallback filters when ATR is unavailable or for additional validation
# FVG_MIN_GAP_PCT: Minimum gap size as % of price (0.03 = 0.03% or 3 basis points)
# Example: At $3000, 0.03% = $0.90 minimum gap
FVG_MIN_GAP_PCT=0.03
# FVG_MIN_GAP_POINTS: Minimum absolute gap size in price units (prevents tiny gaps)
FVG_MIN_GAP_POINTS=0.01

# ========================================
# FVG Strategy Behavior (NEW)
# ========================================
# FVG_MIN_CONFIRM_BARS: Minimum number of closed candles between FVG formation and entry confirmation
# This prevents entering on the candle that forms the FVG (default: 1 = wait at least 1 full candle)
# Increase to 2 or 3 for more conservative entries that require price to revisit the FVG zone
FVG_MIN_CONFIRM_BARS=1

# Strategy now supports BOTH continuation and inversion automatically:
# - CONTINUATION: Candle enters FVG zone, closes in FVG direction (bullish FVG → close above → LONG)
# - INVERSION: Candle enters FVG zone, closes opposite to FVG direction (bullish FVG → close below → SHORT)
# Both are evaluated on every candle close after FVG formation

# ========================================
# FVG Debug & Logging
# ========================================
# FVG_DEBUG_DETECTION: Enable detailed FVG detection logs (true = show all touch/entry attempts)
# Set to 'false' for normal operation (entry logs still show comprehensive data on signals)
FVG_DEBUG_DETECTION=false
# ========================================
# NY-Open FVG Trading Controls
# ========================================
# NY_OPEN_TRADE: Set to 'false' to only log signals without executing trades
# When 'true', trades execute automatically when continuation or inversion signals are confirmed
NY_OPEN_TRADE=true

# NY_OPEN_MAX_TRADES: Maximum number of trades per symbol per day (UTC reset at midnight)
# Recommended: 1-3 to avoid overtrading
NY_OPEN_MAX_TRADES=1

# NY_OPEN_DEBUG: When 'true', send detailed FVG detection logs, error stack traces, and debugging info
# When 'false' (production), show: trade signals with strategy type, entry/exit, OR updates, heartbeats
# Note: Entry signals always show full details (continuation vs inversion, candle data, etc.)
NY_OPEN_DEBUG=false

# NY_OPEN_LOG_KEEPALIVE_SEC: How often to send status update logs when no signals (seconds)
# Set higher (e.g., 900 = 15min) for production to reduce log spam
NY_OPEN_LOG_KEEPALIVE_SEC=900

# Timeframes
HTF=1h
ITF=15m
LTF=1m

# Strategy selection:
# Map per symbol:
# A   = Combo A
# C1  = Trendline Break + EMA Pullback
# C2  = Consolidation Breakout + ATR Expansion
# BR  = Standalone Break & Retest (15m)
# EMA9= Standalone Pullback to 9 EMA (15m)
STRATEGY_MAP=ETH/USDT:A,SOL/USDT:C2,DOGE/USDT:C1,BTC/USDT:BR,XRP/USDT:EMA9


# Risk (ATR model)
# ============== TRADE EXECUTION PARAMETERS ==============
# RISK_NOTIONAL_USDT: Position size in USDT per trade (default for all symbols)
RISK_NOTIONAL_USDT=1000
# RISK_NOTIONAL_MAP: Override position size per symbol
# Format: SYMBOL:USDT_AMOUNT,SYMBOL:USDT_AMOUNT
RISK_NOTIONAL_MAP=ETH/USDT:1000
# Enable dynamic TP/SL by ROI stages (leave empty to disable)

# --- Dynamic ladder uses ROE for stage triggers (what the heartbeat shows) ---
# Stages trigger when ROE crosses these %
# DISABLED: Using LADDER mode's built-in TP-triggered SL progression instead
DYN_ROI_STAGES=

# At each stage, move SL/TP to these *price% vs entry* levels (code interprets as price%):
# (20x leverage mapping: ROE% / 20 = price%)
#  10% ROE -> 0.50% price
#  15% ROE -> 0.75% price
#  20% ROE -> 1.00% price
#  25% ROE -> 1.25% price
#  30% ROE -> 1.50% price
#  35% ROE -> 1.75% price
#
# SL logic (conservative; price% vs entry - always favorable direction):
#  - after 10% ROE: SL -> 0.00% price (BREAKEVEN - entry price, 0% ROI)
#  - after 15% ROE: SL -> 0.25% price (~5% ROE with 20x leverage)
#  - after 20% ROE: SL -> 0.50% price (~10% ROE with 20x leverage)
#  - after 25% ROE: SL -> 0.75% price (~15% ROE with 20x leverage)
#  - after 30% ROE: SL -> 1.00% price (~20% ROE with 20x leverage)
#  - after 35% ROE: SL -> 1.25% price (~25% ROE with 20x leverage)
DYN_SL_AT_STAGE=0.00,0.25,0.50,0.75,1.00,1.25

# TP logic (conservative; keep TP well above SL so position has room to profit):
#  - after 10% ROE: TP -> 0.60% price (~12% ROE with 20x leverage)
#  - after 15% ROE: TP -> 0.85% price (~17% ROE with 20x leverage)
#  - after 20% ROE: TP -> 1.10% price (~22% ROE with 20x leverage)
#  - after 25% ROE: TP -> 1.35% price (~27% ROE with 20x leverage)
#  - after 30% ROE: TP -> 1.60% price (~32% ROE with 20x leverage)
#  - after 35% ROE: TP -> 1.85% price (~37% ROE with 20x leverage)
DYN_TP_AT_STAGE=0.60,0.85,1.10,1.35,1.60,1.85
DYN_MIN_REARM_SECONDS=10        # Cooldown between re-arms per symbol

# Tick-safe stop placement (symbol-aware)
STOP_TICKS_AWAY=2           # keep at least 2 ticks beyond current mark
STOP_BUFFER_PCT_MIN=0.0003  # extra 0.03% guard

# ATR source & brackets (kept same; dynamic ladder will adjust after entry)
ATR_SOURCE=HYBRID
ATR_PERIOD=14
ATR_SL_MULT=1.25
ATR_TP_MULT=2.5
HYBRID_SL_FLOOR_ITF_ATR_MULT=0.6
HYBRID_WICK_BUFFER_PCT=0.0007
HYBRID_TP_ITF_ATR_MULT=1.0

# BRACKET_MODE: How SL/TP are calculated
#   - 'ROE': Based on Return on Equity % (ROE_SL and ROE_TP below)
#   - 'ATR': Uses strategy-provided SL/TP (for FVG: uses FVG_RR)
#   - 'FIXED_PCT': Fixed price percentage (FIXED_SL_PCT and FIXED_TP_PCT)
#   - 'LADDER': Multiple TP levels with partial closes (LADDER_TP_PCT, LADDER_TP_QTY_PCT, LADDER_SL_PCT)
#   - 'LADDER': Multiple TP levels with partial closes (LADDER_TP_PCT, LADDER_TP_QTY_PCT, LADDER_SL_PCT)
# For NY-Open FVG: Set to 'ATR' to use FVG_RR-based brackets
BRACKET_MODE=LADDER
# ROE_SL: Stop-loss as ROE % (negative = loss; e.g., -5 = -5% ROE)
# With 20x leverage: -5% ROE = -0.25% price move
ROE_SL=-5
# ROE_TP: Take-profit as ROE % (positive = profit; e.g., 13 = +13% ROE)
# With 20x leverage: +13% ROE = +0.65% price move
ROE_TP=13
# --- LADDER mode: 3TP system with progressive SL management ---
# LADDER_TP_PCT: Comma-separated ROE % targets for take profit levels
# Single TP: 21 = TP at 21% ROE
# With 20x leverage: 21% ROE = 1.05% price move
LADDER_TP_PCT=21
# LADDER_TP_QTY_PCT: Comma-separated % of position to close at each TP (MUST sum to 100)
# Single TP: 100 = close 100% at TP
LADDER_TP_QTY_PCT=100
# LADDER_SL_PCT: Initial stop-loss as ROE % (negative = loss; e.g., -9 = -9% ROE)
# With 20x leverage: -9% ROE = -0.45% price move
LADDER_SL_PCT=-9
# optional: ROE metric heartbeat & re-arm metric
DYN_METRIC=ROE
DYN_USE_MARK=true
# Leverage & mode
# LEVERAGE: Leverage multiplier (e.g., 20 = 20x leverage)
LEVERAGE=20
# MARGIN_MODE: 'isolated' or 'cross' margin
MARGIN_MODE=isolated

# Behavior
LOG_SIGNALS_ONLY=false
DAILY_LOSS_CAP_USDT=150
COOLDOWN_SECONDS=300
DEBUG_DECISIONS=true


